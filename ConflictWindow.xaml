<Window x:Class="GitXMLTranslator.ConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitXMLTranslator"
        mc:Ignorable="d"
        Title="Разрешение конфликтов" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Обнаружены конфликты. Примите решение." FontSize="20" FontWeight="Bold" Margin="10" HorizontalAlignment="Center"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="FilesList" ItemsSource="{Binding Files}" Grid.Column="0" SelectionChanged="Files_SelectionChanged" DisplayMemberPath="Name"/>
            <Grid Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="ConflictsTable"
                      Grid.Row="0"
                      ItemsSource="{Binding Conflicts}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserSortColumns="True" Margin="10,10,10,10">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="LightBlue"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="LightBlue"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Resolved}" Value="True">
                                    <Setter Property="Background" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        IsReadOnly="True"
                                        Width="100"/>
                        <DataGridTemplateColumn Header="Локальное значение" Width="2*" SortMemberPath="Local">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Local}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         Cursor="IBeam"
                                         FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Значение на сервере" Width="2*" SortMemberPath="Server">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Server}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         Cursor="IBeam"
                                         FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Итог" Width="2*" SortMemberPath="TextResult">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding TextResult}"
                                            BorderThickness="0"
                                            Width="100"
                                            Background="Transparent"
                                            Cursor="IBeam"
                                            FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
                                            IsEnabled="{Binding NotResolved}"
                                            Click="Button_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Утверждено?" Width="2*" SortMemberPath="Resolved">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding TextResolved}"
                                            BorderThickness="0"
                                            Width="100"
                                            Background="Transparent"
                                            Cursor="IBeam"
                                            FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
                                            Click="Resolve_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Grid.Row="1" Click="Finish_Click" Content="Завершить" Height="50" Margin="10, 10, 10, 10" IsEnabled="{Binding AreAllConflictsResolved}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
