<Window x:Class="GitXMLTranslator.GitWindowXML"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitXMLTranslator"
        mc:Ignorable="d"
        Title="GitWindowXML" Height="220" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <TextBlock TextAlignment="Center" Text="Для использования введите никнейм." Margin="10, 10, 10, 0" FontFamily="Segoe UI" FontSize="24" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <TextBox x:Name="Name" Margin="40, 10, 40, 70" VerticalAlignment="Bottom" Height="30" VerticalContentAlignment="Center" TextChanged="TextBox_TextChanged"/>
        <Button x:Name="ContinueButton" Content="Продолжить" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0, 0, 0, 10" Height="40" Width="100" Click="Button_Click" IsEnabled="False"/>
    </Grid>
</Window>
