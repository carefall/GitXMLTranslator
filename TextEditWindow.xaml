<Window x:Class="RestXMLTranslator.TextEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestXMLTranslator"
        mc:Ignorable="d"
        Title="Введите текст" Height="450" Width="800" FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="Editor"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="Ok" Width="80"
                    Margin="5"
                    IsDefault="True"
                    Click="Ok_Click"
                    Content="OK"
                    FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"/>
            <Button Width="80"
                    Margin="5"
                    IsCancel="True"
                    Content="Отмена"
                    FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"/>
        </StackPanel>
    </Grid>
</Window>
